# ─────────────────────────────────────────────────────────
# Stage 1: deps
# Install only production dependencies
# ─────────────────────────────────────────────────────────
FROM node:20-alpine AS deps

# Install pnpm
RUN npm install -g pnpm

WORKDIR /app

# Copy package files first (better Docker layer caching)
# If package.json hasn't changed, Docker skips this step entirely
COPY package.json pnpm-lock.yaml ./

# Install all dependencies (including devDeps needed for build)
RUN pnpm install --frozen-lockfile


# ─────────────────────────────────────────────────────────
# Stage 2: builder
# Compile the Next.js app into production output
# ─────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

RUN npm install -g pnpm

WORKDIR /app

# Copy installed node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy all source code
COPY . .

# Build environment variables
# These are baked in at build time — not runtime
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production

# Run Next.js build
# Outputs to .next/standalone (see next.config.ts below)
RUN pnpm build


# ─────────────────────────────────────────────────────────
# Stage 3: runner
# Final slim image — only what's needed to RUN the app
# No source code, no dev tools, no pnpm
# ─────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Create a non-root user for security
# Never run production apps as root
RUN addgroup --system --gid 1001 nodejs
RUN adduser  --system --uid 1001 nextjs

# Copy ONLY the standalone output from builder
# This is a self-contained Next.js server with minimal footprint
COPY --from=builder /app/public                  ./public
COPY --from=builder /app/.next/standalone        ./
COPY --from=builder /app/.next/static            ./.next/static

# Set correct file ownership
RUN chown -R nextjs:nodejs /app

# Switch to non-root user
USER nextjs

# Expose dashboard port
EXPOSE 4000

ENV PORT=4000
ENV HOSTNAME="0.0.0.0"

# Start the Next.js standalone server
CMD ["node", "server.js"]